rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Song Letters collection
    match /songLetters/{letterId} {
      // Anyone can read (for public memory links)
      allow read: if true;
      
      // Only authenticated users can create
      allow create: if request.auth != null;
      
      // Only sender can update/delete
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.sender_id;
    }
    
    // Replies collection
    match /replies/{replyId} {
      // Anyone can read replies
      allow read: if true;
      
      // Authenticated users can create replies
      allow create: if request.auth != null;
      
      // Only reply sender can update/delete
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.sender_id;
    }
  }
}
